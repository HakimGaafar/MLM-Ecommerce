{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@prisma/client": ["../../node_modules/.prisma/client"]
    }
  },
  "include": ["src/**/*.ts", "prisma/seed.ts"]
}
