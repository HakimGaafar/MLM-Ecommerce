{
  "name": "@mlm/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "prisma": {
    "schema": "./prisma/schema.prisma",
    "seed": "dotenv -e ../../.env -- tsx prisma/seed.ts"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "prisma:migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "prisma:migrate:status": "dotenv -e ../../.env -- prisma migrate status",
    "prisma:reset": "dotenv -e ../../.env -- prisma migrate reset",
    "prisma:seed": "dotenv -e ../../.env -- tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^3.0.2"
  },
  "devDependencies": {
    "@types/node": "^20",
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.6.0",
    "tsx": "^4.20.6"
  }
}
