# Safe template only. Copy to `.env` and provide real values locally.
# Never commit `.env` or any production credentials.

# Required
NEXT_PUBLIC_APP_NAME=Fources
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SUPPORT_URL=mailto:support@yourdomain.com
JWT_SECRET=replace-with-a-long-random-secret-min-32-characters
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret-min-32-chars
AUTH_COOKIE_NAME=mlm_session
AUTH_REFRESH_COOKIE_NAME=mlm_refresh
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mlm_ecommerce?schema=public
REDIS_URL=redis://localhost:6379
PHASE_XII_ENABLED=false

# Optional worker settings (used when PHASE_XII_ENABLED=true)
# WALLET_REWARDS_DISPATCH=queue
# WALLET_SETTLEMENT_DISPATCH=queue
# WORKER_CONCURRENCY=5

# Optional Stripe card payments
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Product image storage (local or S3-compatible)
STORAGE_PROVIDER=local
# S3_BUCKET=your-bucket-name
# S3_REGION=auto
# S3_ENDPOINT=https://your-s3-compatible-endpoint
# CDN_BASE_URL=https://cdn.example.com
# S3_KEY_PREFIX=products
# AWS_ACCESS_KEY_ID=replace-me
# AWS_SECRET_ACCESS_KEY=replace-me
# S3_FORCE_PATH_STYLE=true

# Private KYC document storage
# KYC_STORAGE_PROVIDER=local
# KYC_LOCAL_DIR=storage/kyc-documents
# KYC_S3_BUCKET=your-private-kyc-bucket
# KYC_S3_REGION=auto
# KYC_S3_KEY_PREFIX=kyc-documents
# KYC_S3_ENDPOINT=https://your-s3-compatible-endpoint
# KYC_S3_FORCE_PATH_STYLE=true
# KYC_AWS_ACCESS_KEY_ID=replace-me
# KYC_AWS_SECRET_ACCESS_KEY=replace-me

# Optional market routing
# MARKET_COOKIE_NAME=mlm_active_market
# APP_ROOT_DOMAIN=example.com
# DEFAULT_DEV_MARKET=SA
# GEO_IP_HEADER=CF-IPCountry
# DEV_GEO_COUNTRY=SA

# Optional operational settings
# RATE_LIMIT_FAIL_CLOSED=true
# FULFILLMENT_SLA_NEW_HOURS=48
# FULFILLMENT_SLA_PROCESSING_HOURS=72
# MIN_WITHDRAWAL_AMOUNT_SAR=250
# FORSEIZ_LEGAL_NAME=Marketplace
# FORSEIZ_VAT_TRN=
# FORSEIZ_ADDRESS_LINE1=
# FORSEIZ_ADDRESS_LINE2=
# FORSEIZ_CITY=
# FORSEIZ_POSTAL_CODE=
# FORSEIZ_COUNTRY_CODE=SA
# FORSEIZ_LOGO_URL=
# INVOICE_ALLOW_BEFORE_RETURN_WINDOW=true
# FULFILLMENT_SLA_BYPASS=false
# FULFILLMENT_SLA_DEMO_STUCK=false

# Optional branding links
# NEXT_PUBLIC_SOCIAL_FACEBOOK=https://www.facebook.com/yourpage
# NEXT_PUBLIC_SOCIAL_INSTAGRAM=https://www.instagram.com/yourpage
# NEXT_PUBLIC_SOCIAL_X=https://x.com/yourpage
# NEXT_PUBLIC_SOCIAL_LINKEDIN=https://www.linkedin.com/company/yourpage
